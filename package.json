{
  "name": "agentriot",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --port ${PORT:-3011}",
    "build": "next build",
    "start": "next start --port ${PORT:-3011}",
    "lint": "eslint .",
    "typecheck": "next typegen && tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:admin": "playwright test --config=playwright.admin.config.ts",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.5.6",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
