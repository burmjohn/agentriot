{
  "name": "agentriot",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "next dev --port ${PORT:-3011}",
    "build": "next build",
    "start": "next start --port ${PORT:-3011}",
    "lint": "eslint .",
    "typecheck": "tsx scripts/typecheck.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:admin": "playwright test --config=playwright.admin.config.ts",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.0",
    "@t3-oss/env-nextjs": "0.13.11",
    "better-auth": "1.6.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.2",
    "postgres": "3.4.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@tailwindcss/postcss": "4.2.2",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.10",
    "eslint": "10.2.0",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2",
    "vitest": "4.1.3"
  }
}
