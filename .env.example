NODE_ENV=production

# Coolify shared PostgreSQL connection string.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agentriot

# Public app URL used by site metadata and auth callbacks.
NEXT_PUBLIC_SITE_URL=https://agentriot.example.com

# Backward-compatible alias for existing client code.
NEXT_PUBLIC_APP_URL=https://agentriot.example.com

# Better Auth configuration.
BETTER_AUTH_URL=https://agentriot.example.com
BETTER_AUTH_SECRET=change-me-to-a-long-random-secret-1234

# Required for API key secret encryption. Must be exactly 32 characters.
API_KEY_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Comma-separated list of admin emails allowed to bootstrap access.
ADMIN_EMAIL_ALLOWLIST=admin@example.com
